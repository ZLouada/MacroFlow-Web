# ===========================================
# MacroFlow Backend - Environment Configuration
# ===========================================

# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (MongoDB)
DATABASE_URL="mongodb://user:password@localhost:27017/macroflow?authSource=admin"

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===========================================
# Authentication
# ===========================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# S3-Compatible Storage
# ===========================================
S3_BUCKET=macroflow-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.amazonaws.com

# ===========================================
# Email (SMTP)
# ===========================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@macroflow.com

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# ===========================================
# Frontend URL (for email links)
# ===========================================
FRONTEND_URL=http://localhost:3001

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug
