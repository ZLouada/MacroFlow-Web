{
  "name": "macroflow",
  "version": "1.0.0",
  "description": "MacroFlow - Project Management and Macroeconomic Simulation Platform",
  "private": true,
  "workspaces": [
    ".",
    "client"
  ],
  "scripts": {
    // Backend scripts
    "backend:dev": "tsx watch src/server.ts",
    "backend:build": "tsc",
    "backend:start": "node dist/server.js",
    "backend:prisma:generate": "prisma generate",
    "backend:prisma:migrate": "prisma migrate dev",
    "backend:prisma:migrate:prod": "prisma migrate deploy",
    "backend:prisma:studio": "prisma studio",
    "backend:prisma:seed": "tsx prisma/seed.ts",
    "backend:lint": "eslint src/**/*.ts",
    "backend:test": "jest",
    "backend:test:watch": "jest --watch",
    "backend:test:coverage": "jest --coverage",
    
    // Frontend scripts
    "frontend:dev": "cd client && npm run dev",
    "frontend:build": "cd client && npm run build",
    "frontend:preview": "cd client && npm run preview",
    "frontend:lint": "cd client && npm run lint",
    "frontend:test": "cd client && npm run test",
    "frontend:test:coverage": "cd client && npm run test:coverage",
    "frontend:server": "cd client && npm run server",
    "frontend:server:prod": "cd client && npm run server:prod",
    "frontend:dev:all": "cd client && npm run dev:all",
    
    // Combined scripts
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run backend:build && npm run frontend:build",
    "start": "npm run backend:start",
    "dev:all": "concurrently \"npm run backend:dev\" \"npm run frontend:dev:all\"",
    "lint": "npm run backend:lint && npm run frontend:lint",
    "test": "npm run backend:test && npm run frontend:test",
    "test:coverage": "npm run backend:test:coverage && npm run frontend:test:coverage"
  },
  "keywords": [
    "project-management",
    "macroeconomics",
    "simulation",
    "api",
    "typescript",
    "react",
    "fullstack"
  ],
  "author": "MacroFlow Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    // Backend dependencies
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@prisma/client": "^5.12.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.22.5",
    
    // Frontend dependencies
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.17.0",
    "@tanstack/react-virtual": "^3.0.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "date-fns": "^3.3.1",
    "framer-motion": "^10.18.0",
    "html2canvas": "^1.4.1",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.4.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.1",
    "react-joyride": "^3.0.2",
    "react-router-dom": "^6.21.2",
    "recharts": "^3.8.1",
