{
  "name": "macroflow",
  "version": "1.0.0",
  "description": "MacroFlow - Project Management and Macroeconomic Simulation Platform",
  "private": true,
  "scripts": {
    "backend:dev": "tsx watch src/server.ts",
    "backend:build": "tsc",
    "backend:start": "node dist/server.js",
    "backend:prisma:generate": "prisma generate",
    "backend:prisma:migrate": "prisma migrate dev",
    "backend:prisma:migrate:prod": "prisma migrate deploy",
    "backend:prisma:studio": "prisma studio",
    "backend:prisma:seed": "tsx prisma/seed.ts",
    "backend:lint": "eslint src/**/*.ts",
    "backend:test": "jest",
    "backend:test:watch": "jest --watch",
    "backend:test:coverage": "jest --coverage",
    "frontend:dev": "npm run dev --prefix client",
    "frontend:build": "npm run build --prefix client",
    "frontend:preview": "npm run preview --prefix client",
    "frontend:lint": "npm run lint --prefix client",
    "frontend:test": "npm run test --prefix client",
    "frontend:test:coverage": "npm run test:coverage --prefix client",
    "frontend:server": "npm run server --prefix client",
    "frontend:server:prod": "npm run server:prod --prefix client",
    "frontend:dev:all": "npm run dev:all --prefix client",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run backend:build && npm run frontend:build",
    "start": "npm run backend:start",
    "dev:all": "concurrently \"npm run backend:dev\" \"npm run frontend:dev:all\"",
    "lint": "npm run backend:lint && npm run frontend:lint",
    "test": "npm run backend:test && npm run frontend:test",
    "test:coverage": "npm run backend:test:coverage && npm run frontend:test:coverage",
    "install:all": "npm install && npm install --prefix client",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "project-management",
    "macroeconomics",
    "simulation",
    "api",
    "typescript",
    "react",
    "fullstack"
  ],
  "author": "MacroFlow Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@prisma/client": "^5.12.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.22.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.5",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.12.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
