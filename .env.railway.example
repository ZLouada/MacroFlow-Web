# ===========================================
# MacroFlow Backend - Railway Environment Variables
# ===========================================
# Copy these to Railway's environment variables section

# Server
NODE_ENV=production
PORT=3000
API_VERSION=v1

# Database (MongoDB Atlas) - Use your MongoDB Atlas connection string
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/macroflow?retryWrites=true&w=majority

# Redis - Railway provides this automatically if you add Redis service
# Use the REDIS_URL from Railway's Redis service
REDIS_URL=redis://default:password@host:port
REDIS_PASSWORD=

# JWT Configuration - CHANGE THESE TO SECURE RANDOM STRINGS
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth - Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-railway-app.railway.app/api/v1/auth/google/callback

# S3-Compatible Storage (optional)
S3_BUCKET=macroflow-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.amazonaws.com

# Email SMTP (optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@macroflow.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10

# CORS - Set to your Vercel frontend URL
CORS_ORIGIN=https://your-app.vercel.app
CORS_CREDENTIALS=true

# Frontend URL - Your Vercel deployment URL
FRONTEND_URL=https://your-app.vercel.app

# Logging
LOG_LEVEL=info
