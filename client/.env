# Frontend Environment Variables
# In development, these are proxied through Vite to the backend at localhost:3000
# In production, the frontend is served by the backend, so relative paths work

# API URL - use relative path since Vite proxy handles /api/* requests
VITE_API_URL=/api/v1

# WebSocket URL for real-time features
# Leave empty for auto-detection based on current host
VITE_WS_URL=

# App settings
VITE_APP_NAME=MacroFlow
VITE_APP_VERSION=1.0.0
